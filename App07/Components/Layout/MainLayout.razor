@inherits LayoutComponentBase
@implements IDisposable
@inject App07.Services.ThemeStateService ThemeService

<div class="page @(ThemeService.IsDarkMode ? "theme-dark" : "theme-light")" style="min-height: 100vh;">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <ThemeTopbar />

        <article class="content px-4 py-4">
            @Body
        </article>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += StateHasChanged;
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }
}