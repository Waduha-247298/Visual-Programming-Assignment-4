@page "/login"
@rendermode InteractiveServer
@inject App05.Services.AuthenticationStateService AuthState

<div class="container-fluid min-vh-100 d-flex align-items-center 
justify-content-center bg-light-auth-gradient py-5">
    <div class="card shadow-lg border-0 overflow-hidden"
    style="width: 100%; max-width: 420px; border-radius: 20px;">

        <div class="bg-gradient-auth text-white text-center py-4 px-3">
            <div class="icon-wrapper mb-2">
                <i class="bi bi-shield-lock fs-2"></i>
            </div>
            <h4 class="m-0 fw-bold tracking-wide">Security Gate</h4>
            <p class="text-white-50 small m-0 mt-1">Manage state session properties</p>
        </div>

        <div class="card-body p-4 bg-white text-center">
            @if (!AuthState.IsAuthenticated)
            {
                <div class="mb-4 text-start">
                    <label class="form-label fw-bold text-secondary small 
                    text-uppercase">Username Account</label>
                    <div class="input-group shadow-sm rounded-3 overflow-hidden">
                        <span class="input-group-text bg-light border-end-0 text-muted">
                            <i class="bi bi-person"></i></span>
                        <input type="text" class="form-control border-start-0 bg-light ps-2"
                               @bind="inputUser" placeholder="Enter username..." />
                    </div>
                </div>

                <button class="btn btn-success btn-lg w-100 fw-bold py-2 shadow-sm" 
                @onclick="ExecuteLogin" style="border-radius: 10px;">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Log In
                </button>
            }
            else
            {
                <div class="alert alert-info border-0 p-3 mb-4 rounded-3 
text-start small d-flex align-items-center">
                    <i class="bi bi-info-circle-fill text-primary fs-5 me-3"></i>
                    <div>
                        <span class="d-block text-muted">Active Profile</span>
                        <strong class="text-dark fs-6">@AuthState.CurrentUser</strong>
                    </div>
                </div>

                <button class="btn btn-danger btn-lg w-100 fw-bold py-2 shadow-sm" 
                @onclick="ExecuteLogout" style="border-radius: 10px;">
                    <i class="bi bi-box-arrow-left me-2"></i>Log Out
                </button>
            }
        </div>

        <div class="card-footer bg-light text-center py-3 border-0">
            <span class="text-muted small fw-medium">CS-284L • Visual Programming Lab</span>
        </div>
    </div>
</div>

@code {
    private string inputUser = "";

    private void ExecuteLogin()
    {
        if (!string.IsNullOrWhiteSpace(inputUser))
        {
            AuthState.LogIn(inputUser);
        }
    }

    private void ExecuteLogout()
    {
        AuthState.LogOut();
        inputUser = ""; 
    }
}

<style>
    .bg-light-auth-gradient {
        background: linear-gradient(135deg, #f6f8fb 0%, #e9eef5 100%);
    }

    .bg-gradient-auth {
        background: linear-gradient(135deg, #4a00e0 0%, #8e2de2 100%);
    }

    .icon-wrapper {
        display: inline-flex;
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.15);
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .input-group .form-control:focus {
        background-color: #ffffff !important;
        box-shadow: none;
        border-color: #8e2de2;
    }
</style>