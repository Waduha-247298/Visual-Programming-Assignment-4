@page "/profile"
@rendermode InteractiveServer
@implements IDisposable
@inject App05.Services.AuthenticationStateService AuthState

<div class="container-fluid min-vh-100 d-flex align-items-center 
justify-content-center bg-light-auth-gradient py-5">
    <div class="card shadow-lg border-0 overflow-hidden"
    style="width: 100%; max-width: 480px; border-radius: 20px;">
        <div class="card-body p-5 text-center bg-white">

            @if (AuthState.IsAuthenticated)
            {
                <div class="success-avatar-wrapper mb-3 bg-light-success text-success
                mx-auto rounded-circle d-flex align-items-center justify-content-center"
                style="width: 70px; height: 70px;">
                    <i class="bi bi-person-check fs-1"></i>
                </div>
                <h3 class="fw-bold text-dark m-0">@("Welcome, " + AuthState.CurrentUser + "!")</h3>
                <p class="text-muted small mt-2 mb-0">
                    Your shared session authentication is securely initialized across the system.</p>
            }
            else
            {
                <div class="danger-avatar-wrapper mb-3 bg-light-danger 
                text-danger mx-auto rounded-circle d-flex align-items-center justify-content-center" 
                style="width: 70px; height: 70px;">
                    <i class="bi bi-exclamation-triangle fs-2"></i>
                </div>
                <h4 class="fw-bold text-danger m-0">Access Restricted</h4>
                <p class="text-muted small mt-2 mb-4">Please log in to review your profile configuration logs.</p>
                <a href="/login" class="btn btn-outline-primary fw-bold px-4">Go to Login Portal</a>
            }

        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        AuthState.OnStateChange += StateHasChanged;
    }
    public void Dispose()
    {
        AuthState.OnStateChange -= StateHasChanged;
    }
}

<style>
    .bg-light-success {
        background-color: #f0fdf4;
    }

    .bg-light-danger {
        background-color: #fef2f2;
    }

    }
</style>